<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">


    <!-- First Recent Buy Text -->
    <TextView
        android:id="@+id/textRecent1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/yeonsung_regular"
        android:text="Recent Buy"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Card Layout -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/recentCard"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textRecent1">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/recentbuyitem"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

        <!-- Image -->
        <ImageView
            android:id="@+id/recentImage"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerCrop"
            android:src="@drawable/menu1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Food Name -->
        <TextView
            android:id="@+id/recentFoodName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/yeonsung_regular"
            android:text="FoodName"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/orderestatus"
            app:layout_constraintStart_toEndOf="@id/recentImage"
            app:layout_constraintTop_toTopOf="@id/recentImage" />

        <!-- Price -->
        <TextView
            android:id="@+id/recentFoodPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/yeonsung_regular"
            android:text="$10"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/recentFoodName"
            app:layout_constraintTop_toBottomOf="@id/recentFoodName" />
        <!-- STATUS -->
        <androidx.cardview.widget.CardView
            android:id="@+id/orderestatus"
            android:layout_width="90dp"
            android:layout_height="36dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#B5BDB6"
            app:cardCornerRadius="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Pending"
                android:textColor="@android:color/white"
                android:textSize="12sp" />
        </androidx.cardview.widget.CardView>

        <!-- OTP -->
        <TextView
            android:id="@+id/otpText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="OTP: ----"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/orderestatus"
            app:layout_constraintStart_toStartOf="@id/orderestatus"
            app:layout_constraintTop_toBottomOf="@id/orderestatus" />


            <!-- ⭐ Feedback Button -->
            <!-- ⭐ Feedback Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRate"
                android:layout_width="82dp"
                android:layout_height="28dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/addtocartshape"
                android:fontFamily="@font/yeonsung_regular"
                android:text="⭐ Rate Now"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:padding="0dp"
                android:visibility="gone"

                app:layout_constraintTop_toBottomOf="@id/orderestatus"
                app:layout_constraintStart_toStartOf="@id/orderestatus"
                app:layout_constraintEnd_toEndOf="@id/orderestatus"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Second Recent Buy Text -->
    <TextView
        android:id="@+id/textRecent2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/yeonsung_regular"
        android:text="Recent Buy"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/recentCard" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/buyAgainRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/textRecent2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/buy_again_item" />
</androidx.constraintlayout.widget.ConstraintLayout>
